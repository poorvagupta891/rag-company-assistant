# Environment variables for cloud deployment
# Copy to .streamlit/secrets.toml (not committed to GitHub)

# Ollama server URL
# Local: http://localhost:11434
# Remote: https://your-ollama-server.com or ngrok URL
OLLAMA_URL = "http://localhost:11434"

# Path to company documents
# Local: /Users/poorvagupta/Downloads/Company_Documents for RAG/
# Cloud: relative path or remote URL
DOCUMENT_PATH = "/Users/poorvagupta/Downloads/Company_Documents for RAG/"

# Optional: API keys if using external services
# API_KEY = "your-key-here"
